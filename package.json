{
  "name": "netlify-csstricks",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maplol/netlify-csstricks"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prestart": "node scripts/gen-ow-config.js",
    "prebuild": "node scripts/gen-ow-config.js",
    "build:css": "postcss src/css/main.css -o src/css/styles.css",
    "start": "npm run build:css && eleventy --serve",
    "dev": "npm run build:css && netlify dev",
    "minify:js": "esbuild dist/js/weather.js --minify --outfile=dist/js/weather.js --allow-overwrite && esbuild dist/js/firebase-app.js --minify --outfile=dist/js/firebase-app.js --allow-overwrite",
    "build": "npm run build:css && eleventy && npm run minify:js",
    "serve": "npm run build && npx serve dist -p 3000"
  },
  "dependencies": {
    "@11ty/eleventy": "^2.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "cssnano": "^7.1.3",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.4",
    "netlify-cli": "^24.0.1",
    "sharp": "^0.34.5"
  }
}
